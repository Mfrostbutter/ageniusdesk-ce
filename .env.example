# ── AgeniusDesk CE configuration ──────────────────────────────────────────────
# Copy to .env and edit. Every value is optional unless noted.

# Dashboard port on the host (container always listens on 3000).
# PORT=3000

# Encrypted-secrets master key. Leave unset to auto-generate at data/.secret_key
# (back it up: losing it makes stored secrets unrecoverable).
# SECRET_KEY=

# Require in-app auth on a naked-port bind. Leave false if you front the app with
# an auth proxy (Cloudflare Access, Authelia, etc.). Set true for a bare public bind.
# When true, the /ws WebSocket also requires an edge-auth identity header.
AGD_REQUIRE_AUTH=false
# Admin bearer token accepted on privileged routes when AGD_REQUIRE_AUTH=true.
# AGD_ADMIN_TOKEN=

# Verify TLS on outbound calls to n8n / MCP servers. Set false only for a
# self-signed n8n on a trusted LAN.
AGD_TLS_VERIFY=true

# ── Optional: security hardening ──────────────────────────────────────────────
# Restrict CORS to specific origins (comma-separated). Default "*" allows any.
# AGD_CORS_ORIGINS=https://app.example.com
# Max request body size in bytes (default 25 MiB). Requests over this get 413.
# AGD_MAX_REQUEST_BYTES=26214400
# Content-Security-Policy header (opt-in; empty = no CSP). The editors load from
# CDNs (cdn.jsdelivr.net, esm.sh) and the music tab embeds arbitrary origins, so
# a strict policy can break features. Recommended starting point if you want one:
# AGD_CSP=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://esm.sh; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; worker-src 'self' blob:; img-src 'self' data: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'

# ── AI providers (set the one(s) you use) ─────────────────────────────────────
# ANTHROPIC_KEY=
# OPEN_AI_KEY=
# OPEN_ROUTER_KEY=
# OLLAMA_URL=http://host.docker.internal:11434

# ── Optional: knowledge RAG backend (point at your own Qdrant) ────────────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Optional: Docker / Containers tab ─────────────────────────────────────────
# Comma-separated hostnames or IPs that THIS host is known by on your LAN.
# Needed only when the dashboard runs in Docker and your n8n instance URLs use
# the host's LAN IP, so the container can recognize a local instance.
# AGD_HOST_ALIASES=myhost,myhost.local,192.0.2.10

# ── Optional: notification sinks (operator-supplied; no defaults) ─────────────
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
