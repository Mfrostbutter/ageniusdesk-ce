# ── AgeniusDesk CE configuration ──────────────────────────────────────────────
# Copy to .env and edit. Every value is optional unless noted.

# Dashboard port on the host (container always listens on 3000).
# PORT=3000

# Encrypted-secrets master key. Leave unset to auto-generate at data/.secret_key
# (back it up: losing it makes stored secrets unrecoverable).
# SECRET_KEY=

# Local account login is ON by default. AGD_REQUIRE_AUTH is an extra hard gate
# for token/edge-auth deployments, and keeps auth required even if
# AGD_DISABLE_LOGIN=true.
AGD_REQUIRE_AUTH=false
# Admin bearer token accepted on internal API routes when set.
# AGD_ADMIN_TOKEN=
# Trust Cloudflare Access / reverse-proxy identity headers. Only enable when the
# dashboard is reachable exclusively through that trusted proxy.
# AGD_TRUST_EDGE_AUTH=false
# Trust X-Forwarded-For for login throttling. Only enable behind a trusted proxy.
# AGD_TRUST_FORWARDED_FOR=false

# ── Local account login (accounts + sessions + optional 2FA) ──────────────────
# On first run the browser forces you to create an owner account, then requires
# login. An edge identity (Cloudflare Access) still satisfies the gate without a
# local account. Set true to turn browser login OFF (dev/localhost only).
# AGD_DISABLE_LOGIN=false
# Session lifetime (sliding) and a hard absolute cap, in days.
# AGD_SESSION_TTL_DAYS=14
# AGD_SESSION_ABSOLUTE_DAYS=30
# Failed-login lockout: attempts before lockout, and lockout duration (minutes).
# AGD_LOGIN_MAX_ATTEMPTS=8
# AGD_LOGIN_LOCKOUT_MINUTES=15
# Password policy for new accounts, resets, and changes. Default: 12 chars with
# an uppercase, a lowercase, a number, and a symbol. Relax any class by setting
# it false (length always applies).
# AGD_PASSWORD_MIN_LENGTH=12
# AGD_PASSWORD_REQUIRE_UPPER=true
# AGD_PASSWORD_REQUIRE_LOWER=true
# AGD_PASSWORD_REQUIRE_NUMBER=true
# AGD_PASSWORD_REQUIRE_SYMBOL=true
# Password-reset link lifetime (minutes).
# AGD_PASSWORD_RESET_TTL_MINUTES=30

# ── Email (SMTP) — password reset ─────────────────────────────────────────────
# Used to send the "forgot password" reset link. If AGD_SMTP_HOST is unset, the
# reset link is written to the container log instead (self-hosted fallback).
# AGD_SMTP_HOST=smtp.example.com
# AGD_SMTP_PORT=587
# AGD_SMTP_USER=apikey-or-username
# AGD_SMTP_PASSWORD=your-smtp-password
# AGD_SMTP_FROM=ageniusdesk@example.com   # defaults to AGD_SMTP_USER when blank
# AGD_SMTP_STARTTLS=true
# Public base URL used to build links in emails (else falls back to the request
# origin). Set this for any non-localhost deployment behind a proxy.
# AGD_PUBLIC_URL=https://app.example.com

# Verify TLS on outbound calls to n8n / MCP servers. Set false only for a
# self-signed n8n on a trusted LAN.
AGD_TLS_VERIFY=true

# ── Optional: security hardening ──────────────────────────────────────────────
# Restrict CORS to specific origins (comma-separated). Default "*" allows any.
# AGD_CORS_ORIGINS=https://app.example.com
# Optional token for the legacy /api/errors/webhook and /api/messages/webhook
# ingest endpoints. New integrations should prefer X-API-Key protected /api/v1.
# AGD_WEBHOOK_TOKEN=
# Optional bearer token for /api/mcp-dashboard, for external MCP clients.
# DASHBOARD_MCP_TOKEN=
# Max request body size in bytes (default 25 MiB). Requests over this get 413.
# AGD_MAX_REQUEST_BYTES=26214400
# Content-Security-Policy header (opt-in; empty = no CSP). The editors load from
# CDNs (cdn.jsdelivr.net, esm.sh) and the music tab embeds arbitrary origins, so
# a strict policy can break features. Recommended starting point if you want one:
# AGD_CSP=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://esm.sh; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; worker-src 'self' blob:; img-src 'self' data: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'

# ── Optional: OpenTelemetry observability (embedded OTLP receiver) ────────────
# Receive per-execution, per-node spans from n8n and render them as a trace
# waterfall in the Observability view. Off by default. The ingest endpoint is a
# machine-ingest surface; set AGD_OTEL_TOKEN before exposing the port publicly.
# AGD_OTEL_ENABLED=false
# Bearer token n8n must send. Unset = open (trusted-LAN only). On the n8n side:
#   N8N_OTEL_ENABLED=true
#   N8N_OTEL_EXPORTER_OTLP_ENDPOINT=http://<this-host>:<PORT>/api/otel   # n8n appends /v1/traces
#   N8N_OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <AGD_OTEL_TOKEN>
# AGD_OTEL_TOKEN=
# Bounded retention (pruned on ingest): oldest spans dropped past either cap.
# AGD_OTEL_RETENTION_HOURS=72
# AGD_OTEL_MAX_SPANS=500000

# ── AI providers (set the one(s) you use) ─────────────────────────────────────
# ANTHROPIC_KEY=
# OPEN_AI_KEY=
# OPEN_ROUTER_KEY=
# OLLAMA_URL=http://host.docker.internal:11434

# ── Optional: knowledge RAG backend (point at your own Qdrant) ────────────────
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Optional: Docker / Containers tab ─────────────────────────────────────────
# Comma-separated hostnames or IPs that THIS host is known by on your LAN.
# Needed only when the dashboard runs in Docker and your n8n instance URLs use
# the host's LAN IP, so the container can recognize a local instance.
# AGD_HOST_ALIASES=myhost,myhost.local,192.0.2.10

# ── Optional: notification sinks (operator-supplied; no defaults) ─────────────
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
